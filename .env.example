# ========================
# Migration Source & Target Variables
# ========================

# [필수] 소스 사이트 URL (스크래핑 대상 쇼핑몰 URL)
# 예: SOURCE_URL="https://www.your-source-shop.com"
SOURCE_URL="https://example-source.com"

# [필수] Shopify 타겟 스토어 URL (.myshopify.com 도메인)
# 예: TARGET_URL="your-store.myshopify.com"
TARGET_URL="example-target.myshopify.com"

# ========================
# API & Authentication Tokens
# ========================

# [필수] Shopify Admin API 액세스 토큰
# Shopify 어드민 > 앱 및 세일즈 채널 > 앱 개발 > API 자격 증명에서 발급
TARGET_API_TOKEN="your_api_token_here"

# ========================
# Path Settings (Optional)
# ========================
# DATA_DIR="data"
